# Deployed BlurVault addresses, one per strategy. Leave a value out and that
# strategy renders as "NOT DEPLOYED" rather than showing invented numbers.
#
# These are NEXT_PUBLIC_* because the browser calls the contracts directly.
# Nothing secret belongs here: every value is visible in the shipped bundle.
NEXT_PUBLIC_VAULT_STEADY=
NEXT_PUBLIC_VAULT_BALANCED=
NEXT_PUBLIC_VAULT_GROWTH=

# Override only on a custom domain; Vercel supplies its own otherwise.
# NEXT_PUBLIC_SITE_URL=https://example.com
